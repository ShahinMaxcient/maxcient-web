// Prisma schema for the Maxcient admin (Phase 1)
// Postgres (Neon in production). Run `npx prisma migrate dev` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (-pooler) — used by the app at runtime
  directUrl = env("DIRECT_URL")   // unpooled — used by `prisma migrate`
}

enum Role {
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

// Admin users who can sign in to the dashboard.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Leads captured from the public consultation form.
model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String?
  source    String     @default("consultation-form")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// Blog / news articles managed from the admin.
model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?
  content     String?    // markdown / rich text
  category    String?
  coverImage  String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([publishedAt])
}

// Homepage "Services" cards.
model Service {
  id        String   @id @default(cuid())
  num       String   @default("")
  title     String
  desc      String
  href      String   @default("#")
  span      String   @default("lg:col-span-2")
  variant   String   @default("default") // default | flagship | accent | dark
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Homepage "Who We Are" testimonial / value cards.
model Testimonial {
  id        String   @id @default(cuid())
  tag       String
  quote     String
  rating    Int      @default(5)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Editable content for the service / solution / industry detail pages,
// keyed by the page's existing route slug (e.g. "microsoft-dynamics-365").
model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  subtitle       String?
  heroImage      String?
  intro          String?
  faqs           Json?    // [{ question, answer }]
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Flexible key/value store for global site settings and section copy
// (e.g. "contact", "social", "footer", "home.hero", "home.servicesHead").
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// Homepage "Industries" bento cards.
model Industry {
  id        String   @id @default(cuid())
  title     String
  num       String   @default("")
  href      String   @default("#")
  image     String   @default("")
  span      String   @default("lg:col-span-4")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Homepage "Technologies" cards.
model Technology {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  letter      String   @default("")
  href        String   @default("#")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// Homepage "Products" rows.
model Product {
  id        String   @id @default(cuid())
  num       String   @default("")
  title     String
  desc      String   @default("")
  tags      String[] @default([])
  href      String   @default("#")
  image     String   @default("")
  subItems  Json?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// "Trusted by" client logos.
model Client {
  id        String   @id @default(cuid())
  name      String
  logo      String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Homepage FAQ items.
model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Homepage "By the numbers" stats.
model Stat {
  id        String   @id @default(cuid())
  value     Int      @default(0)
  suffix    String   @default("")
  eyebrow   String   @default("")
  label     String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Footer office locations.
model Office {
  id        String   @id @default(cuid())
  region    String
  city      String
  address   String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Marquee scrolling band items.
model MarqueeItem {
  id        String   @id @default(cuid())
  text      String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// About page — company values.
model CompanyValue {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// About page — at-a-glance stats.
model AboutStat {
  id        String   @id @default(cuid())
  label     String
  value     String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// Per-page feature items (service/solution/industry pages).
model PageFeature {
  id          String   @id @default(cuid())
  pageSlug    String
  title       String
  description String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageSlug, order])
}
